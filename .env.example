# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for production.
# Add your Vercel deployment URL here when using Vercel (frontend) + VPS (backend).
# Example: ALLOWED_ORIGINS=https://fairarena.app,https://fairarena-git-main-yourteam.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# ── Upstash Redis (optional – in-memory fallback used if not set) ─────────────
UPSTASH_REDIS_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_TOKEN=<your-token>

# ── Session limits ────────────────────────────────────────────────────────────
# Max concurrent global Docker/PTY sessions
MAX_SESSIONS=3
# Per-IP max active session (Redis-enforced; keep at 1 for fairness)
MAX_SESSIONS_PER_IP=1
SESSION_TTL_MS=1800000       # 30 minutes
# Per-IP daily allowance in milliseconds
DAILY_LIMIT_MS=3600000       # 1 hour per day

# ── Resource gating ───────────────────────────────────────────────────────────
# Reject new terminal sessions when CPU or RAM exceeds this % (10-99)
OVERLOAD_THRESHOLD=50
# Kill ALL active sessions when CPU or RAM exceeds this % (must be > OVERLOAD_THRESHOLD)
KILL_THRESHOLD=60
# How often to sample server resources (ms)
OVERLOAD_CHECK_MS=5000

# ── Security ──────────────────────────────────────────────────────────────────
# Allow the proxy (/api/request/run) to reach private/localhost IPs
# NEVER enable on a public-facing server unless you know what you're doing
ALLOW_PRIVATE_PROXY=false

# ── WebSocket rate limiting ───────────────────────────────────────────────────
WS_MSG_RATE_LIMIT=120        # max messages per minute per connection
WS_CONN_IDLE_MS=300000       # close idle WS connections after 5 min
